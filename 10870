import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        int result = 0;

        result = fibonacci(n);

        System.out.println(result);

        sc.close();
    }
    public static int fibonacci(int n) {
        if(n == 1 || n == 2) return 1;
        else return fibonacci(n - 1) + fibonacci(n -2);
    }
}
